<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bushenyi Farm Health Advisor"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primaryText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detect banana bacterial wilt and coffee leaf rust early."
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:textColor="@color/secondaryText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select crop"
            android:layout_marginTop="20dp"
            android:textColor="@color/primaryText" />

        <Spinner
            android:id="@+id/cropSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select symptoms seen in the field"
            android:layout_marginTop="20dp"
            android:textColor="@color/primaryText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <CheckBox
                android:id="@+id/wiltingCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Leaves wilting" />
            <CheckBox
                android:id="@+id/yellowLeavesCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yellow leaves" />
            <CheckBox
                android:id="@+id/boiledAppearanceCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Boiled or greasy leaf appearance" />
            <CheckBox
                android:id="@+id/oozeCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bacterial ooze on pseudostem" />
            <CheckBox
                android:id="@+id/rustSpotsCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rust-colored spots on coffee" />
            <CheckBox
                android:id="@+id/defoliationCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Leaf defoliation" />
            <CheckBox
                android:id="@+id/powderyDustCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Powdery dust on leaves" />
            <CheckBox
                android:id="@+id/brownNecrosisCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Brown necrosis" />
            <CheckBox
                android:id="@+id/stuntedGrowthCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stunted growth" />
        </LinearLayout>

        <Button
            android:id="@+id/submitButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Report"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/buttonColor"
            android:textColor="@color/buttonText" />

        <LinearLayout
            android:id="@+id/advisoryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background">

            <TextView
                android:id="@+id/resultTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Result title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primaryText" />

            <TextView
                android:id="@+id/resultConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/secondaryText" />

            <TextView
                android:id="@+id/resultRisk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/secondaryText" />

            <TextView
                android:id="@+id/resultList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/secondaryText" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
