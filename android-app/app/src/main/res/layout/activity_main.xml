<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bushenyi Farm Health Advisor"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primaryText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detect banana bacterial wilt and coffee leaf rust early."
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:textColor="@color/secondaryText" />

        <TextView
            android:id="@+id/farmerNameLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Farmer Name"
            android:textColor="@color/primaryText" />

        <EditText
            android:id="@+id/farmerNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Jane"
            android:inputType="textPersonName"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/phoneLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textColor="@color/primaryText"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/phoneInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="256 7XX XXX XXX"
            android:inputType="phone"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/locationLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location (Subcounty)"
            android:textColor="@color/primaryText"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/locationInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bushenyi"
            android:inputType="text"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select crop"
            android:layout_marginTop="20dp"
            android:textColor="@color/primaryText" />

        <Spinner
            android:id="@+id/cropSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select symptoms seen in the field"
            android:layout_marginTop="20dp"
            android:textColor="@color/primaryText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <CheckBox
                android:id="@+id/wiltingCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Leaves wilting" />
            <CheckBox
                android:id="@+id/yellowLeavesCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yellow leaves" />
            <CheckBox
                android:id="@+id/boiledAppearanceCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Boiled or greasy leaf appearance" />
            <CheckBox
                android:id="@+id/oozeCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bacterial ooze on pseudostem" />
            <CheckBox
                android:id="@+id/rustSpotsCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rust-colored spots on coffee" />
            <CheckBox
                android:id="@+id/defoliationCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Leaf defoliation" />
            <CheckBox
                android:id="@+id/powderyDustCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Powdery dust on leaves" />
            <CheckBox
                android:id="@+id/brownNecrosisCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Brown necrosis" />
<CheckBox
                android:id="@+id/stuntedGrowthCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stunted growth" />
            <CheckBox
                android:id="@+id/rottenPseudostemCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rotten pseudostem" />
            <CheckBox
                android:id="@+id/leafSpotsCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Leaf spots" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Additional notes"
            android:textColor="@color/primaryText"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/commentsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Additional notes"
            android:inputType="textMultiLine"
            android:minHeight="60dp"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/capturePhotoButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Take Photo of Leaf"
            android:layout_marginTop="16dp"
            style="@android:style/Widget.DeviceDefault.Button" />

        <ImageView
            android:id="@+id/photoPreview"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <Button
            android:id="@+id/submitButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Report"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/buttonColor"
            android:textColor="@color/buttonText" />

        <LinearLayout
            android:id="@+id/advisoryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background">

            <TextView
                android:id="@+id/resultTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Result title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primaryText" />

            <TextView
                android:id="@+id/resultConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/secondaryText" />

            <TextView
                android:id="@+id/resultSeverity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/secondaryText" />

            <TextView
                android:id="@+id/resultList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/secondaryText" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
